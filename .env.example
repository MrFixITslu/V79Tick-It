# ─── Server Config ────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
ALLOWED_ORIGINS=https://your-domain.com,http://localhost:5174

# ─── Secrets (GENERATE THESE - node scripts/generate-secrets.js) ──────────────
# Cryptographically strong secrets are REQUIRED in production.
JWT_SECRET=
SUPER_ADMIN_JWT_SECRET=
COOKIE_SECRET=

# ─── Gemini AI ───────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ─── Email (Gmail App Password) ──────────────────────────────────────────────
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ─── Super Admin ─────────────────────────────────────────────────────────────
SUPER_ADMIN_EMAIL=admin@v79tickit.com
SUPER_ADMIN_PASSWORD=

# ─── Stripe (Production keys) ────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# ─── Subscription Config ─────────────────────────────────────────────────────
TRIAL_DAYS=14
PLAN_PRICE_STARTER=29
PLAN_PRICE_PRO=79
PLAN_PRICE_ENTERPRISE=199

# Base URL for email links
PORTAL_BASE_URL=https://your-domain.com
